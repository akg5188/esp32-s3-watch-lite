# Copy this file to .env.voice-gateway and edit only the values you need.
#
# Default is safest for public tunnel use: only expose port 8790 on this computer.
# If the watch must connect directly over home LAN, change this to 0.0.0.0.
WATCH_VOICE_BIND=127.0.0.1

# Usually leave these empty: voice_gateway.py will read tools/watch_gateway/watch_gateway_config.json.
WATCH_GATEWAY_API_URL=
WATCH_GATEWAY_API_KEY=
WATCH_GATEWAY_MODEL=

# Default Docker mode: use the upstream OpenAI-compatible provider for ASR/TTS.
# This is lighter than running Whisper inside the container.
WATCH_VOICE_STT_PROVIDER=upstream
WATCH_VOICE_STT_MODEL=whisper-1
WATCH_VOICE_TTS_PROVIDER=local
WATCH_VOICE_TTS_MODEL=tts-1
WATCH_VOICE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Only enable this after the watch firmware is configured to send the same Bearer token.
WATCH_VOICE_TOKEN=

# Optional Cloudflare Tunnel token. In Zero Trust, route the public hostname to:
# http://voice-gateway:8790
CLOUDFLARE_TUNNEL_TOKEN=

WATCH_VOICE_TIMEOUT=90
WATCH_VOICE_LOG_LEVEL=INFO
